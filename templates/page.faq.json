          "settings": {
            "heading": "How do I place an order on FitFlop?",
            "open": false,
            "content": "<p>Find the product you wish to buy</p><p>Select the size of the product</p><p>Add the product to your shopping bag by clicking on \"Add to Bag\"</p><p>Go to your shopping bag and click on \"Checkout\"</p><p>Provide your Shipping Address</p><p>Confirm payment and your order will be placed<br/></p>",

          "type": "collapsible_tab",
          "settings": {
            "heading": "Do I need to create an account to place an order?",
            "open": false,
            "content": "<p>No, you can place an order without signing in. We will take your contact details for order communications during checkout. However, we recommend creating an account for a personalized experience and seamless order tracking.</p>",
            "page": "",
            "custom_liquid": ""
          }
        },

:wrap; }\n.foot-select {\n  padding: 14px 20px; border-radius: 40px; border: 1px solid #e5e5e5;\n  font-size: 16px; width:160px; cursor:pointer; background:#fff;\n}\n.calc-btn {\n  width:100%; padding:16px 0; border-radius:40px; background:#30afb5;\n  color:#fff; font-size:18px; font-weight:700; border:none; cursor:pointer;\n  margin-top: 10px;\n}\n\n.result-box {\n  margin-top:25px; padding:20px; border:1px solid #ddd;\n  text-align:left; background:#fafafa; border-radius:10px;\n}\n.result-box h3 {\n  margin-top: 0;\n  margin-bottom: 15px;\n  font-size: 20px;\n}\n.result-box p {\n  margin: 8px 0;\n}\n</style>\n\n\n<script>\n(function () {\n\n  // Complete women's size chart based on the provided table\n  const womenChart = [\n    { len:[216,220], wid:{n:218,a:220,w:221}, eu:35, uk:2, us:4 },\n    { len:[221,225], wid:{n:221,a:223,w:225}, eu:36, uk:3, us:5 },\n    { len:[226,230], wid:{n:225,a:226,w:228}, eu:37, uk:4, us:6 },\n    { len:[231,235], wid:{n:228,a:230,w:231}, eu:38, uk:5, us:7 },\n    { len:[236,240], wid:{n:231,a:233,w:235}, eu:39, uk:6, us:8 },\n    { len:[241,245], wid:{n:235,a:237,w:238}, eu:40, uk:7, us:9 },\n    { len:[246,250], wid:{n:238,a:240,w:242}, eu:41, uk:8, us:10 },\n    { len:[251,255], wid:{n:242,a:243,w:245}, eu:42, uk:9, us:11 },\n    { len:[256,260], wid:{n:245,a:246,w:248}, eu:43, uk:10, us:12 }\n  ];\n\n  function widthCategory(width, row) {\n    if (width <= row.wid.n) return \"NARROW\";\n    if (width <= row.wid.a) return \"STANDARD\";\n    return \"WIDE\";\n  }\n\n  function initCalculator(wrapper) {\n\n    const btn = wrapper.querySelector(\".calc-btn\");\n    const result = wrapper.querySelector(\".result-box\");\n\n    btn.addEventListener(\"click\", function () {\n\n      const ll = Number(wrapper.querySelector(\".left-length\").value);\n      const lw = Number(wrapper.querySelector(\".left-width\").value);\n      const rl = Number(wrapper.querySelector(\".right-length\").value);\n      const rw = Number(wrapper.querySelector(\".right-width\").value);\n\n      if (!ll || !lw || !rl || !rw) {\n        alert(\"Please select all measurements.\");\n        return;\n      }\n\n      const length = Math.max(ll, rl);\n      const width = Math.max(lw, rw);\n\n      let matched = womenChart.find(r => length >= r.len[0] && length <= r.len[1]);\n\n      if (!matched) {\n        result.style.display = \"block\";\n        result.innerHTML = \"<b>No matching size found for your measurements. Please contact customer service for assistance.</b>\";\n        return;\n      }\n\n      const widthText = widthCategory(width, matched);\n      const lengthCm = (length / 10).toFixed(1);\n      const widthCm = (width / 10).toFixed(1);\n\n      result.style.display = \"block\";\n      result.innerHTML = `\n        <h3>Recommended Size (Women)</h3>\n        <p style=\"font-size:18px;\"><b>UK ${matched.uk} | US ${matched.us} | EU ${matched.eu}</b></p>\n        <p><b>Recommended Width:</b> ${widthText}</p>\n\n        <p style=\"margin-top:15px;\"><b>Based on Your Measurements:</b><br>\n           Length: ${lengthCm} cm (largest foot)<br>\n           Width: ${widthCm} cm (largest foot)\n        </p>\n\n        <div style=\"margin-top:15px; padding:15px; background:#fff; border-left:4px solid #000; border-radius:5px;\">\n          <b>Sizing Tip:</b> At FitFlop, we always say: Not quite sure about your size? \n          Choose the next size up! Your feet naturally expand throughout the day,\n          and we want you to stay comfortable.\n        </div>\n      `;\n    });\n  }\n\n  document\n    .querySelectorAll('[data-foot-size-widget=\"women\"]')\n    .forEach(initCalculator);\n\n})();\n</script>"

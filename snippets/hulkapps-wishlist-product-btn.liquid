{% assign button_layout = 'simple_button' %}
{% if shop.metafields.hulkapps_wishlist.hulkapps_wishlist_general.button_layout != null %}
{% assign button_layout = shop.metafields.hulkapps_wishlist.hulkapps_wishlist_general.button_layout %}
{% endif %}
{% assign wishlist_button_style = shop.metafields.hulkapps_wishlist.hulkapps_wishlist_buttonstyle.button_style %}
<a href="#" class="icon-wishlist-heart-empty wishlist-btn grid-wishlist-btn heart-wishlist-animation"
data-wishList data-added="false" data-proID="{{ product.id }}"
data-varID="{{ product.selected_or_first_available_variant.id }}"
data-button-layout="{{ button_layout }}" style="display:none">
<div class="hulk_wl_icon-text" hulk-wl-custom-style
data-count="{{ shop.metafields.hulkapps_wishlist.hulkapps_wishlist_general.public_wishlist_count }}">
<div class="hulk_wl_icon">
<i class="heart-hulk-animation"><i class="icon-wishlist-heart-empty"></i></i>
{% comment %}<span>Add to wishlist</span> {% endcomment %}
</div>
</div>
{% assign compact_count_style = false %}
{% if button_layout == 'multi_color_button' %}
  {% if wishlist_button_style == 'style_2' or wishlist_button_style == 'style_4' %}
    {% assign compact_count_style = true %}
  {% endif %}
{% endif %}
{% if compact_count_style %}
<span class="count" hulk-wl-custom-style>0</span>
{% else %}
<span class="count" hulk-wl-custom-style>(0)</span>
{% endif %}
</a>

{%- comment -%}
  Add this snippet to your product template or in a separate snippet file
  that gets included in your product page (e.g., snippets/size-chart-modal.liquid)
{%- endcomment -%}

{%- comment -%} Size Chart Modal {%- endcomment -%}
<modal-dialog id="SizeChartModal" class="size-chart-modal">
  <div role="dialog" aria-modal="true" class="size-chart-modal__content" tabindex="-1">
    <div class="size-chart-modal__header">
      <h2 class="size-chart-modal__title" id="SizeChartModalTitle"></h2>

      <button 
        id="SizeChartModalClose" 
        type="button" 
        class="size-chart-modal__close" 
        aria-label="{{ 'accessibility.close' | t }}"
      >
        {% render 'svg-icons' with 'close' %}
      </button>
    </div>
    <div class="size-chart-modal__body rte" id="SizeChartModalContent">
      <p>Loading size chart...</p>
    </div>
  </div>
</modal-dialog>

{%- comment -%}
  Hidden container with size chart content for each collection
  The JavaScript will read from here based on which collections the product belongs to
{%- endcomment -%}
<div class="size-chart-data" style="display:none;">
  {%- for collection in product.collections -%}
    {%- assign size_chart_page = collection.metafields.custom.size_chart.value -%}
    {%- if size_chart_page -%}
      <div 
        class="size-chart-page-content" 
        data-collection-handle="{{ collection.handle }}"
      data-size-chart-title="{{ size_chart_page.title }}"

      >
        {{ size_chart_page.content }}
      </div>
    {%- endif -%}
  {%- endfor -%}
</div>

{%- comment -%} Pass product collections to JavaScript {%- endcomment -%}
<script type="application/json" id="ProductCollectionsJSON">
  {{ product.collections | map: 'handle' | json }}
</script>

<style>
  /* Size Chart Modal Styles */
  .size-chart-modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 9999;
    background: rgba(0, 0, 0, 0.5);
    align-items: center;
    justify-content: center;
  }

  .size-chart-modal.is-open {
    display: flex;
  }

  .size-chart-modal__content {
    background: white;
    max-width: 800px;
    width: 90%;
    max-height: 90vh;
    overflow-y: auto;
    border-radius: 8px;
    position: relative;
  }

  .size-chart-modal__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 30px;
    border-bottom: 1px solid #e5e5e5;
    sticky: top 0;
    background: white;
    z-index: 1;
  }

  .size-chart-modal__title {
    margin: 0;
    font-size: 24px;
    font-weight: 600;
  }

  .size-chart-modal__close {
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.2s;
  }

  .size-chart-modal__close:hover {
    opacity: 0.7;
  }

  .size-chart-modal__close svg {
    width: 20px;
    height: 20px;
  }

  .size-chart-modal__body {
    padding: 30px;
  }

  .size-chart-modal__body table {
    width: 100%;
    border-collapse: collapse;
    margin: 20px 0;
  }

  .size-chart-modal__body th,
  .size-chart-modal__body td {
    padding: 12px;
    text-align: center !important;
    border: 1px solid #e5e5e5;
  }

  .size-chart-modal__body th {
    background: #f5f5f5;
    font-weight: 600;
  }

  /* Size Chart Trigger Button Styles */
  .size-chart-trigger {
    background: none;
    border: none;
    color: inherit;
    {% comment %} text-decoration: underline; {% endcomment %}
    cursor: pointer;
    font-size: inherit;
    padding: 0;
    margin-left: 10px;
    transition: opacity 0.2s;
  }

 .size-chart-trigger:hover {
    font-weight: bold;
  } 

  /* Hide size chart data container */
  .size-chart-data {
    display: none !important;
  }
</style>
{{- 'video.css' | asset_url | stylesheet_tag -}}
{%- liquid
	assign section_heading = section.settings.heading
	assign section_heading_left = section.settings.heading_left
	assign section_description = section.settings.description
	assign section_width = section.settings.section_width
	assign video = section.settings.video
	assign video_hosted = section.settings.video_hosted
	assign video_mobile = section.settings.video_mobile
	assign video_autoplay = section.settings.video_autoplay
	assign aspect_ratio = section.settings.aspect_ratio
	assign disable_top_spacing = section.settings.disable_top_spacing
	assign disable_bottom_spacing = section.settings.disable_bottom_spacing
-%}
<div class="row {{ section_width }}">
	<div class="small-12 columns">
		<div class="video-section section-spacing{% if disable_top_spacing %} section-spacing--disable-top{% endif %}{% if disable_bottom_spacing %} section-spacing--disable-bottom{% endif %}">
			<div class="video-section__inner">
				{% render 'section-header', section_heading: section_heading, section_description: section_description, section_heading_left: section_heading_left %}
				<div class="video-section__container video-aspect--{{ aspect_ratio }}">
					{%- if video_hosted != blank -%}
						{%- liquid
							assign sizes = '1340x'
							if section_width == 'full-width-row' or section_width == 'full-width-row-full'
								assign sizes = '1600x'
							endif
						-%}
						<div class="video-desktop">
							{{ video_hosted | video_tag: autoplay: video_autoplay, loop: true, controls: true, muted: video_autoplay, image_size: sizes, class: 'video-player' }}
						</div>
						{%- if video_mobile != blank -%}
							<div class="video-mobile">
								{{ video_mobile | video_tag: autoplay: video_autoplay, loop: true, controls: true, muted: video_autoplay, image_size: '800x', class: 'video-player' }}
							</div>
						{%- else -%}
							<div class="video-mobile">
								{{ video_hosted | video_tag: autoplay: video_autoplay, loop: true, controls: true, muted: video_autoplay, image_size: '800x', class: 'video-player' }}
							</div>
						{%- endif -%}
					{%- elsif video != blank -%}
						{%- if video.type == 'youtube' -%}
							<iframe src="https://www.youtube.com/embed/{{ video.id }}?loop=1{%- if video_autoplay -%}&autoplay=1&mute=1{%- endif -%}&playlist={{ video.id }}&iv_load_policy=3&disablekb=1&controls=1&playsinline=1" frameborder="0" allow="autoplay; encrypted-media" allowfullscreen title="{{ section.settings.heading | escape }}" tabindex="-1" loading="eager"></iframe>
						{%- else -%}
							<iframe src="https://player.vimeo.com/video/{{ video.id }}{%- if video_autoplay -%}?background=1{%- endif -%}" frameborder="0" allow="autoplay; encrypted-media" allowfullscreen title="{{ section.settings.heading | escape }}" tabindex="-1" loading="eager"></iframe>
						{%- endif -%}
					{%- endif -%}
				</div>
			</div>
		</div>
	</div>
</div>

<style>
/* Video Section Container */
.video-section__container {
	position: relative;
	width: 100%;
	overflow: hidden;
	background: #000;
}

/* Desktop: First Fold Video (100vh) */
.video-section__container.video-aspect--16-9 {
	height: 100vh;
	min-height: 600px;
	max-height: 1080px;
}

.video-section__container.video-aspect--9-16 {
	height: 100vh;
	min-height: 600px;
}

.video-section__container.video-aspect--4-3 {
	height: 100vh;
	min-height: 600px;
	max-height: 900px;
}

.video-section__container.video-aspect--3-4 {
	height: 100vh;
	min-height: 600px;
}

.video-section__container.video-aspect--square {
	height: 100vh;
	min-height: 600px;
	max-height: 1000px;
}

/* Video Player Styles */
.video-section__container .video-player,
.video-section__container iframe {
	position: absolute;
	top: 50%;
	left: 50%;
	transform: translate(-50%, -50%);
	width: 100%;
	height: 100%;
	object-fit: cover;
	display: block;
	z-index: 1;
}

/* Ensure iframe fills container properly */
.video-section__container iframe {
	min-width: 100%;
	min-height: 100%;
}

/* Mobile/Desktop Toggle */
.video-mobile {
	display: none;
}

.video-desktop {
	display: block;
}

/* Tablet Styles (768px - 1024px) */
@media screen and (max-width: 1024px) and (min-width: 769px) {
	.video-section__container.video-aspect--16-9,
	.video-section__container.video-aspect--9-16,
	.video-section__container.video-aspect--4-3,
	.video-section__container.video-aspect--3-4,
	.video-section__container.video-aspect--square {
		height: 70vh;
		min-height: 500px;
	}
}

/* Mobile Styles (up to 768px) */
@media screen and (max-width: 768px) {
	.video-desktop {
		display: none;
	}
	
	.video-mobile {
		display: block;
	}
	
	/* Mobile: Aspect ratio based heights */
	.video-section__container.video-aspect--16-9 {
		height: auto;
		aspect-ratio: 16/9;
		min-height: 300px;
		max-height: 60vh;
	}
	
	.video-section__container.video-aspect--9-16 {
		height: 80vh;
		min-height: 400px;
		max-height: 800px;
	}
	
	.video-section__container.video-aspect--4-3 {
		height: auto;
		aspect-ratio: 4/3;
		min-height: 300px;
		max-height: 60vh;
	}
	
	.video-section__container.video-aspect--3-4 {
		height: 70vh;
		min-height: 400px;
	}
	
	.video-section__container.video-aspect--square {
		height: auto;
		aspect-ratio: 1/1;
		min-height: 300px;
		max-height: 500px;
	}
}

/* Small Mobile (up to 480px) */
@media screen and (max-width: 480px) {
	.video-section__container.video-aspect--16-9,
	.video-section__container.video-aspect--4-3 {
		min-height: 250px;
		max-height: 50vh;
	}
	
	.video-section__container.video-aspect--square {
		max-height: 400px;
	}
	
	.video-section__container.video-aspect--9-16 {
		height: 70vh;
		min-height: 350px;
		max-height: 700px;
	}
}
 
/* Full Width Adjustments */
.full-width-row .video-section,
.full-width-row-full .video-section {
	margin-left: calc(-50vw + 50%);
	margin-right: calc(-50vw + 50%);
	width: 100vw;
}

.full-width-row-full .video-section {
	padding: 0;
}
</style>

{% schema %}
{
	"name": "custom Video",
	"class": "section-video",
	"settings": [
		{
			"type": "text",
			"id": "heading",
			"label": "Heading",
			"default": "Video"
		},
		{
			"type": "checkbox",
			"id": "heading_left",
			"default": false,
			"label": "Left align heading"
		},
		{
			"type": "richtext",
			"id": "description",
			"label": "Description",
			"default": "<p>Add a short description for this section</p>"
		},
		{
			"type": "select",
			"id": "section_width",
			"options": [
				{
					"value": "grid",
					"label": "Grid"
				},
				{
					"value": "full-width-row",
					"label": "Full width"
				},
				{
					"value": "full-width-row-full",
					"label": "Full width, no spacing"
				}
			],
			"default": "grid",
			"label": "Section width"
		},
		{
			"type": "header",
			"content": "Desktop Video"
		},
		{
			"type": "video_url",
			"id": "video",
			"label": "Video URL",
			"accept": [
				"youtube",
				"vimeo"
			],
			"placeholder": "Use a YouTube or Vimeo URL",
			"default": "https://www.youtube.com/watch?v=_9VUPq3SxOc"
		},
		{
			"type": "video",
			"id": "video_hosted",
			"label": "Shopify-hosted video",
			"info": "Overrides the Video URL setting."
		},
		{
			"type": "header",
			"content": "Mobile Video (Optional)"
		},
		{
			"type": "video",
			"id": "video_mobile",
			"label": "Mobile video",
			"info": "Optional: Upload a separate video optimized for mobile. If empty, desktop video will be used."
		},
		{
			"type": "header",
			"content": "Video Settings"
		},
		{
			"type": "checkbox",
			"id": "video_autoplay",
			"default": true,
			"label": "Autoplay",
			"info": "Video will be muted"
		},
		{
			"type": "select",
			"id": "aspect_ratio",
			"options": [
				{
					"value": "16-9",
					"label": "16/9 (Landscape)"
				},
				{
					"value": "9-16",
					"label": "9/16 (Portrait)"
				},
				{
					"value": "4-3",
					"label": "4/3"
				},
				{
					"value": "3-4",
					"label": "3/4"
				},
				{
					"value": "square",
					"label": "Square (1:1)"
				}
			],
			"default": "16-9",
			"label": "Video aspect ratio"
		},
		{
			"type": "header",
			"content": "Spacing"
		},
		{
			"type": "checkbox",
			"id": "disable_top_spacing",
			"default": false,
			"label": "Remove top spacing"
		},
		{
			"type": "checkbox",
			"id": "disable_bottom_spacing",
			"default": false,
			"label": "Remove bottom spacing"
		}
	],
	"presets": [
		{
			"name": "Video"
		}
	],
	"enabled_on": {
		"templates": ["*"],
		"groups": [
			"header", 
			"footer"
		]
	}
}
{% endschema %}